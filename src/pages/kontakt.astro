---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import { company, physicalLocations } from '@data/site';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Kontakt',
  description: `Kontaktiere ${company.name}. Telefon: ${company.phone}, E-Mail: ${company.email}`,
  mainEntity: {
    '@type': 'Organization',
    name: company.name,
    telephone: company.phone,
    email: company.email,
  },
};
---

<BaseLayout
  title="Kontakt & Anmeldung"
  description={`Kontaktiere Fahrschule Antonio Marino. Telefon: ${company.phone}, E-Mail: ${company.email}. Termin buchen für Fahrstunden, VKU oder Nothelferkurs.`}
  schema={contactSchema}
>
  <Hero
    eyebrow="Kontakt"
    title="Kontaktiere"
    titleHighlight="Antonio."
    subtitle="Telefon, WhatsApp oder Formular – du entscheidest. Antwort innerhalb von 24 Stunden."
    showCTA={false}
    backgroundVariant="minimal"
  />

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info reveal">
          <h3 style="margin-bottom: var(--sp-6);">Direkter Draht</h3>

          <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="contact-method">
            <div class="contact-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="contact-label">Telefon</span>
              <span class="contact-value">{company.phone}</span>
            </div>
          </a>

          <a href={`mailto:${company.email}`} class="contact-method">
            <div class="contact-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="contact-label">E-Mail</span>
              <span class="contact-value">{company.email}</span>
            </div>
          </a>

          <a href={`https://wa.me/41${company.phone.replace(/\s/g, '').replace('+41', '')}`} target="_blank" rel="noopener" class="contact-method">
            <div class="contact-icon" style="color: #25D366;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm5.49-7.415c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            </div>
            <div>
              <span class="contact-label">WhatsApp</span>
              <span class="contact-value">Nachricht senden</span>
            </div>
          </a>

          <div class="contact-locations">
            <h4 style="margin-bottom: var(--sp-4); margin-top: var(--sp-8);">Unsere Standorte</h4>
            {physicalLocations.map(loc => (
              <div class="location-item">
                <span class="location-dot">●</span>
                <div>
                  <strong>{loc.name}</strong>
                  {loc.address.street && <span>{loc.address.street}, {loc.address.zip} {loc.address.city}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Form -->
        <div class="contact-form-wrapper reveal reveal-delay-1">
          <div class="contact-form-card glass">
            <h3 style="margin-bottom: var(--sp-5);">Anfrage senden</h3>
            <form id="contact-form" class="contact-form" novalidate>
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Name *</label>
                  <input type="text" id="name" name="name" required autocomplete="name" placeholder="Dein Name" />
                </div>
                <div class="form-group">
                  <label for="phone">Telefon *</label>
                  <input type="tel" id="phone" name="phone" required autocomplete="tel" placeholder="078 123 45 67" />
                </div>
              </div>

              <div class="form-group">
                <label for="email">E-Mail *</label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="deine@email.ch" />
              </div>

              <div class="form-group">
                <label for="service">Gewünschte Leistung</label>
                <select id="service" name="service">
                  <option value="">Bitte wählen…</option>
                  <option value="fahrstunden">Fahrstunden</option>
                  <option value="vku">Verkehrskundeunterricht (VKU)</option>
                  <option value="nothelferkurs">Nothelferkurs</option>
                  <option value="pruefungsvorbereitung">Prüfungsvorbereitung</option>
                  <option value="kontrollfahrt">Kontrollfahrt</option>
                  <option value="motorradgrundkurs">Motorradgrundkurs</option>
                  <option value="sonstiges">Sonstiges</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">Nachricht</label>
                <textarea id="message" name="message" rows="4" placeholder="Wann möchtest du starten? In welcher Sprache? Hast du besondere Fragen?"></textarea>
              </div>

              <!-- Cloudflare Turnstile -->
              <div class="cf-turnstile" data-sitekey="0x4XXXXXXXXXXXXXXXXX" data-theme="dark"></div>

              <div class="form-group">
                <label class="checkbox-label">
                  <input type="checkbox" id="privacy" name="privacy" required />
                  <span>Ich habe die <a href="/datenschutz" style="color: var(--c-accent);">Datenschutzerklärung</a> gelesen und stimme zu.</span>
                </label>
              </div>

              <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;" id="submit-btn">
                Anfrage senden
              </button>

              <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-10);
  align-items: start;
}

.contact-method {
  display: flex;
  gap: var(--sp-4);
  align-items: center;
  padding: var(--sp-4);
  border-radius: var(--r-md);
  transition: background var(--t-fast);
  margin-bottom: var(--sp-3);
}

.contact-method:hover {
  background: var(--c-surface);
}

.contact-icon {
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-accent-dim);
  border-radius: var(--r-md);
  color: var(--c-accent);
  flex-shrink: 0;
}

.contact-label {
  display: block;
  font-size: var(--fs-xs);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--c-text-dim);
  margin-bottom: 2px;
}

.contact-value {
  display: block;
  font-family: var(--font-display);
  font-weight: var(--fw-semibold);
}

.location-item {
  display: flex;
  gap: var(--sp-3);
  align-items: flex-start;
  margin-bottom: var(--sp-3);
}

.location-dot {
  color: var(--c-accent);
  font-size: 8px;
  margin-top: 6px;
}

.location-item span {
  display: block;
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
}

/* Form */
.contact-form-card {
  padding: var(--sp-8);
  border-radius: var(--r-lg);
  border: 1px solid var(--c-border);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-4);
  margin-bottom: var(--sp-4);
}

.form-group {
  margin-bottom: var(--sp-4);
}

.form-group label {
  display: block;
  font-size: var(--fs-sm);
  font-weight: var(--fw-medium);
  margin-bottom: var(--sp-2);
  color: var(--c-text-muted);
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: var(--sp-3) var(--sp-4);
  background: var(--c-bg);
  border: 1px solid var(--c-border-strong);
  border-radius: var(--r-md);
  color: var(--c-text);
  font-size: var(--fs-base);
  transition: border-color var(--t-fast);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--c-accent);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
  color: var(--c-text-dim);
}

.form-group textarea {
  resize: vertical;
}

.checkbox-label {
  display: flex !important;
  align-items: flex-start;
  gap: var(--sp-2);
  font-size: var(--fs-sm) !important;
  cursor: pointer;
}

.checkbox-label input {
  width: auto !important;
  margin-top: 3px;
}

.form-status {
  margin-top: var(--sp-4);
  font-size: var(--fs-sm);
  text-align: center;
  min-height: 1.5em;
}

.form-status.success {
  color: var(--c-success);
}

.form-status.error {
  color: var(--c-cta);
}

.cf-turnstile {
  margin-bottom: var(--sp-4);
  min-height: 65px;
}

#submit-btn.loading {
  opacity: 0.7;
  pointer-events: none;
}

@media (max-width: 768px) {
  .contact-grid {
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }
  .form-row {
    grid-template-columns: 1fr;
  }
  .contact-form-card {
    padding: var(--sp-5);
  }
}
</style>

<!-- Cloudflare Turnstile Script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
const form = document.getElementById('contact-form');
const status = document.getElementById('form-status');
const submitBtn = document.getElementById('submit-btn');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  status.className = 'form-status';
  status.textContent = '';
  submitBtn.classList.add('loading');

  const data = new FormData(form);
  const turnstileToken = data.get('cf-turnstile-response');

  if (!turnstileToken) {
    status.className = 'form-status error';
    status.textContent = 'Bitte bestätige, dass du kein Roboter bist.';
    submitBtn.classList.remove('loading');
    return;
  }

  try {
    // Submit to Cloudflare Function
    const response = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: data.get('name'),
        phone: data.get('phone'),
        email: data.get('email'),
        service: data.get('service'),
        message: data.get('message'),
        'cf-turnstile-response': turnstileToken,
      }),
    });

    if (response.ok) {
      status.className = 'form-status success';
      status.textContent = '✅ Anfrage gesendet! Antonio meldet sich innerhalb von 24 Stunden bei dir.';
      form.reset();
    } else {
      throw new Error('Server error');
    }
  } catch (err) {
    status.className = 'form-status error';
    status.textContent = '❌ Etwas ist schiefgelaufen. Bitte versuche es telefonisch: 078 826 10 61';
  } finally {
    submitBtn.classList.remove('loading');
  }
});
</script>
