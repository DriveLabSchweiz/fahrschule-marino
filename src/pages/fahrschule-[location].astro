---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTASection from '@components/CTASection.astro';
import FAQ from '@components/FAQ.astro';
import ServiceCard from '@components/ServiceCard.astro';
import { allLocations, getLocation, services, company, physicalLocations, priceList, reviews } from '@data/site';

export const getStaticPaths = () => {
  return allLocations.map(loc => ({
    params: { location: loc.slug },
    props: { location: loc },
  }));
};

const { location } = Astro.props;

// Generate unique content per location
const locName = location.name;
const locShort = location.nameShort;
const locCanton = location.canton;
const phoneLink = company.phone.replace(/\s/g, '');
const nearbyLocations = location.nearby
  .map(slug => getLocation(slug))
  .filter(Boolean)
  .slice(0, 4);

// Preis-Teaser: die beiden Einzellektionen (45/75 Min) aus site.ts.
const teaserLessons = priceList.filter(p => p.duration === '45 Min' || p.duration === '75 Min');

// Local-specific FAQ
const localFAQ = [
  {
    question: `Wo finde ich eine Fahrschule in ${locShort}?`,
    answer: `Die Fahrschule Antonio Marino ist ${location.tier === 1 ? 'mit einer Adresse in ' + locName + ' vertreten' : 'in ' + locName + ' und Umgebung aktiv'}. Ruf an unter ${company.phone} oder schreibe über WhatsApp, um deinen ersten Termin zu vereinbaren.`,
  },
  {
    question: `Welche Leistungen bietet die Fahrschule in ${locShort} an?`,
    answer: `In ${locShort} bieten wir Fahrstunden, Verkehrskundeunterricht (VKU), Nothelferkurse, Prüfungsvorbereitung und Vorbereitung auf die Kontrollfahrt an. Alle Leistungen kannst du bei Antonio Marino in deiner Sprache buchen – auf Deutsch, Italienisch, Englisch, Französisch oder Spanisch.`,
  },
  {
    question: `Kann ich in ${locShort} abgeholt werden?`,
    answer: `Ja! Wir bieten einen Abholservice in ${locShort} und Umgebung. Vereinbare einfach einen Treffpunkt, der dir passt – wir kommen zu dir.`,
  },
  {
    question: `Wie lange dauert der Weg zum Führerschein in ${locCanton}?`,
    answer: `Im Kanton ${locCanton} gilt derselbe Ablauf wie in der ganzen Schweiz: Nothelferkurs, Theorieprüfung, VKU, Fahrstunden und praktische Prüfung. Mit regelmässigen Fahrstunden bist du typischerweise in 3 bis 6 Monaten bereit für die Prüfung.`,
  },
];

// Local schema
const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${company.url}/fahrschule-${location.slug}#localbusiness`,
  name: `Fahrschule Antonio Marino ${locShort}`,
  parentOrganization: { '@id': `${company.url}/#organization` },
  telephone: company.phone,
  email: company.email,
  url: `${company.url}/fahrschule-${location.slug}`,
  priceRange: company.priceRange,
  address: location.address.street ? {
    '@type': 'PostalAddress',
    streetAddress: location.address.street,
    postalCode: location.address.zip,
    addressLocality: location.address.city,
    addressRegion: location.canton,
    addressCountry: 'CH',
  } : {
    '@type': 'PostalAddress',
    postalCode: location.address.zip,
    addressLocality: location.address.city,
    addressRegion: location.canton,
    addressCountry: 'CH',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: location.geo.lat,
    longitude: location.geo.lng,
  },
  areaServed: { '@type': 'City', name: location.address.city },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '07:00',
    closes: '21:00',
  }],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: company.url },
    { '@type': 'ListItem', position: 2, name: 'Standorte', item: `${company.url}/standorte` },
    { '@type': 'ListItem', position: 3, name: locName, item: `${company.url}/fahrschule-${location.slug}` },
  ],
};
---

<BaseLayout
  title={`Fahrschule ${locShort} – Fahrstunden & VKU | Antonio Marino`}
  description={`Fahrschule Antonio Marino in ${locName}: Fahrstunden, VKU, Nothelferkurs und Prüfungsvorbereitung. ${location.tier === 1 ? 'Adresse: ' + location.address.street + ', ' + location.address.zip + ' ' + location.address.city + '.' : 'Lokale Expertise, flexible Zeiten, 5 Sprachen.'} Jetzt anrufen: ${company.phone}.`}
  schema={[localSchema, breadcrumbSchema]}
>
  <Hero
    eyebrow={`Fahrschule ${locShort}`}
    title={`Fahren lernen in`}
    titleHighlight={locName}
    subtitle={`${location.tier === 1 ? 'Direkt bei dir vor Ort' : 'Mit lokaler Expertise und persönlichem Abholservice'} – erfahrener Fahrlehrer, flexible Zeiten und 5 Sprachen. Dein Weg zum Führerschein beginnt hier.`}
    image="/antonio-hero.jpeg"
    imageAlt={`Antonio Marino mit seinem modernen Fahrschulauto – Fahrschule in ${locName}`}
  />

  <!-- Trust-Leiste mit animierten Countern -->
  <section class="section-sm trust-strip-section">
    <div class="container">
      <div class="trust-strip glass reveal">
        <div class="trust-item">
          <span class="trust-num" data-count="4.9" data-count-decimals="1" data-count-suffix="/5">4.9/5</span>
          <span class="trust-label">Google-Bewertung</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-num" data-count="63">63</span>
          <span class="trust-label">Bewertungen</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-num" data-count="5">5</span>
          <span class="trust-label">Sprachen</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-num" data-count="10" data-count-suffix="+">10+</span>
          <span class="trust-label">Jahre Erfahrung</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="location-intro-grid">
        <div data-anim="fade-up">
          <p class="eyebrow">{locName}</p>
          <h2 style="margin-bottom: var(--sp-5);">
            Willkommen bei der Fahrschule Antonio Marino in {locShort}
          </h2>
          <p style="font-size: var(--fs-lg); margin-bottom: var(--sp-4); line-height: var(--lh-relaxed);">
            {location.tier === 1
              ? `Unser Standort in ${locName} liegt ${location.address.street ? 'an der ' + location.address.street : 'zentral im Ort'}. Hier starten deine Fahrstunden, besuchst du den Verkehrskundeunterricht und bereitest du dich optimal auf die praktische Prüfung vor.`
              : `In ${locName} und Umgebung sind wir aktiv mit Abholservice und individueller Betreuung. Ob du das erste Mal hinter dem Lenker sitzt oder dich auf die Kontrollfahrt vorbereitest – wir bringen dich sicher ans Ziel.`}
          </p>
          <p style="color: var(--c-text-muted); margin-bottom: var(--sp-4);">
            Als lokale Fahrschule kennen wir die Besonderheiten der Strassen in {locShort} und der Region {location.canton}. Wir wissen, welche Kreuzungen tricky sind, wo du im Verkehr vorausschauend fahren musst und welche Routen im Prüfungsgebiet relevant sind. Dieses Wissen geben wir dir in jeder Fahrstunde weiter.
          </p>
          <p style="color: var(--c-text-muted);">
            Unser Ziel: dich sicher, selbstbewusst und mit Freude zum Führerschein zu führen. Auf Deutsch, Italienisch, Englisch, Französisch oder Spanisch – in der Sprache, die du verstehst.
          </p>

          <div style="display: flex; gap: var(--sp-3); margin-top: var(--sp-6); flex-wrap: wrap;">
            <a href={`tel:${phoneLink}`} class="btn btn-primary btn-magnetic">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {company.phone}
            </a>
            <a href="/kontakt" class="btn btn-ghost">
              Anfrage senden
            </a>
          </div>
        </div>

        <div class="location-info-card" data-anim="slide-left" data-anim-delay="0.12">
          {location.address.street && (
            <div class="info-item">
              <span class="info-label">Adresse</span>
              <span class="info-value">{location.address.street}, {location.address.zip} {location.address.city}</span>
            </div>
          )}
          <div class="info-item">
            <span class="info-label">Region</span>
            <span class="info-value">{location.address.city} ({location.canton})</span>
          </div>
          <div class="info-item">
            <span class="info-label">Telefon</span>
            <a href={`tel:${phoneLink}`} class="info-value info-link">{company.phone}</a>
          </div>
          <div class="info-item">
            <span class="info-label">E-Mail</span>
            <a href={`mailto:${company.email}`} class="info-value info-link">{company.email}</a>
          </div>
          <div class="info-item">
            <span class="info-label">Sprachen</span>
            <span class="info-value">{company.languages.join(', ')}</span>
          </div>
          <div class="info-item">
            <span class="info-label">Öffnungszeiten</span>
            <span class="info-value">Mo–Sa, 07:00–21:00<br><span style="color: var(--c-text-dim); font-size: var(--fs-sm);">Nach Vereinbarung</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow reveal">Leistungen in {locShort}</p>
        <h2 class="reveal" data-anim-delay="0.05">Was wir in {locShort} anbieten</h2>
        <p class="section-lead reveal" data-anim-delay="0.1">
          Von der ersten Fahrstunde bis zur bestandenen Prüfung – alles aus einer Hand,
          in der Sprache, die du verstehst.
        </p>
      </header>
      <div class="services-grid">
        {services.map((service, i) => (
          <ServiceCard service={service} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Preis-Teaser -->
  <section class="section price-teaser-section">
    <div class="road-line price-teaser-road" aria-hidden="true"></div>
    <div class="container">
      <header class="section-head">
        <p class="eyebrow reveal">Preise in {locShort}</p>
        <h2 class="reveal" data-anim-delay="0.05">Faire Preise, keine Überraschungen</h2>
        <p class="section-lead reveal" data-anim-delay="0.1">
          Transparente Lektionspreise – inkl. Abholservice in {locShort}. Mit unseren
          Sparpaketen fährst du pro Lektion noch günstiger.
        </p>
      </header>

      <div class="price-teaser-grid">
        {teaserLessons.map((item, i) => (
          <article
            class={`price-teaser-card card ${item.popular ? 'is-popular' : ''} reveal`}
            data-anim-delay={(i * 0.08).toFixed(2)}
          >
            {item.popular && <span class="ribbon ribbon-gold">Beliebteste</span>}
            <span class="price-teaser-duration">{item.duration}</span>
            <div class="price-teaser-amount">
              <span class="price-teaser-cur">CHF</span>
              <span class="price-teaser-num">{item.price}</span>
            </div>
            <p class="price-teaser-desc">{item.description}</p>
          </article>
        ))}

        <article class="price-teaser-card price-teaser-cta-card reveal" data-anim-delay="0.16">
          <h3 class="price-teaser-cta-title">Sparpakete &amp; Intensivkurse</h3>
          <p class="price-teaser-cta-text">
            Abos ab <strong>CHF&nbsp;930</strong> – bis zu <strong>CHF&nbsp;572</strong> Ersparnis.
            VKU, Nothelfer &amp; Motorrad auf Anfrage.
          </p>
          <div class="price-teaser-actions">
            <a href="/preise" class="btn btn-primary btn-magnetic" style="width:100%;">
              Alle Preise ansehen
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/kontakt" class="btn btn-ghost" style="width:100%;">Angebot anfragen</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Why here -->
  <section class="section why-here-section">
    <div class="why-here-glow" aria-hidden="true"></div>
    <div class="container">
      <header class="section-head">
        <p class="eyebrow reveal">Warum in {locShort}?</p>
        <h2 class="reveal" data-anim-delay="0.05">Lokale Expertise, die den Unterschied macht</h2>
        <p class="section-lead reveal" data-anim-delay="0.1">
          Wir kennen {locShort} und die Region {locCanton} – und geben dir genau dieses
          Wissen in jeder Fahrstunde mit.
        </p>
      </header>
      <div class="why-here-grid">
        <div class="why-here-card" data-anim="fade-up">
          <span class="why-here-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </span>
          <h4>Strassenkenntnis {locShort}</h4>
          <p>Wir trainieren auf den Strassen, die für die praktische Prüfung in {locShort} und Umgebung relevant sind. Du lernst die schwierigen Kreuzungen, Tempo-30-Zonen und die typischen Prüfungsrouten kennen.</p>
        </div>
        <div class="why-here-card" data-anim="fade-up" data-anim-delay="0.08">
          <span class="why-here-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>
          </span>
          <h4>Abholservice</h4>
          <p>Du wirst in {locShort} oder an einem vereinbarten Treffpunkt abgeholt. Kein Stress mit der Anreise – du startest entspannt in deine Fahrstunde.</p>
        </div>
        <div class="why-here-card" data-anim="fade-up" data-anim-delay="0.16">
          <span class="why-here-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </span>
          <h4>5 Sprachen</h4>
          <p>In {locShort} unterrichten wir auf Deutsch, Italienisch, Englisch, Französisch und Spanisch. Lerne in der Sprache, in der du dich am wohlsten fühlst.</p>
        </div>
        <div class="why-here-card" data-anim="fade-up" data-anim-delay="0.24">
          <span class="why-here-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </span>
          <h4>Flexible Zeiten</h4>
          <p>Fahrstunden auch nach Feierabend und am Wochenende. Wir passen uns deinem Terminkalender an – nicht umgekehrt.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title={`Bereit für deine erste Fahrstunde in ${locShort}?`}
    subtitle={`Ruf Antonio an, schreibe eine WhatsApp oder fülle das Formular aus – Antwort innerhalb von 24 Stunden. ${reviews.ratingValue}/5 aus ${reviews.reviewCount} Google-Bewertungen.`}
  />

  <FAQ items={localFAQ} title={`FAQ Fahrschule ${locShort}`} />

  <!-- Nearby -->
  {nearbyLocations.length > 0 && (
    <section class="section nearby-section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow reveal">In der Nähe</p>
          <h2 class="reveal" data-anim-delay="0.05">Auch bei dir um die Ecke</h2>
          <p class="section-lead reveal" data-anim-delay="0.1">
            Antonio Marino unterrichtet in der ganzen Region. Finde deinen Standort in der Nähe von {locShort}.
          </p>
        </header>
        <div class="nearby-grid">
          {nearbyLocations.map((near, i) => (
            <a
              href={`/fahrschule-${near!.slug}`}
              class="nearby-card"
              data-anim="fade-up"
              data-anim-delay={(i * 0.06).toFixed(2)}
            >
              <span class="nearby-pin" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="nearby-text">
                <span class="nearby-name">{near!.name}</span>
                <span class="nearby-sub">Fahrschule {near!.nameShort}</span>
              </span>
              <span class="nearby-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
        <p class="nearby-all reveal" data-anim-delay="0.1">
          <a href="/standorte" class="text-accent">Alle Standorte ansehen →</a>
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
.location-intro-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: var(--sp-8);
  align-items: start;
}

.location-info-card {
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  padding: var(--sp-6);
  position: sticky;
  top: calc(var(--header-height) + var(--sp-5));
}

.info-item {
  padding: var(--sp-3) 0;
  border-bottom: 1px solid var(--c-border);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  display: block;
  font-size: var(--fs-xs);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--c-text-dim);
  margin-bottom: 4px;
}

.info-value {
  display: block;
  font-weight: var(--fw-medium);
}

.info-link {
  color: var(--c-accent);
  transition: opacity var(--t-fast);
}

.info-link:hover {
  opacity: 0.8;
}

/* ── Section-Köpfe (geteiltes Muster mit /preise) ─────────────────── */
.section-head {
  max-width: 720px;
  margin-bottom: var(--sp-8);
}
.section-head h2 {
  font-size: clamp(2rem, 4vw + 1rem, 3rem);
  margin-bottom: var(--sp-4);
}
.section-lead {
  color: var(--c-text-muted);
  font-size: var(--fs-lg);
  line-height: var(--lh-relaxed);
}
.section-lead strong { color: var(--c-accent-bright); }

/* ── Trust-Leiste ─────────────────────────────────────────────────── */
.trust-strip-section { padding-top: 0; }
.trust-strip {
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: var(--sp-5);
  flex-wrap: wrap;
  padding: var(--sp-5) var(--sp-6);
  border-radius: var(--r-lg);
  border: 1px solid var(--c-border-gold);
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--sp-1);
}
.trust-num {
  font-family: var(--font-display);
  font-size: var(--fs-2xl);
  font-weight: var(--fw-extrabold);
  color: var(--c-accent);
  line-height: 1;
}
.trust-label {
  font-size: var(--fs-xs);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--c-text-muted);
}
.trust-divider {
  width: 1px;
  align-self: stretch;
  min-height: 36px;
  background: var(--c-border-strong);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--sp-5);
}

/* ── Preis-Teaser ─────────────────────────────────────────────────── */
.price-teaser-section { position: relative; overflow: hidden; }
.price-teaser-road {
  top: 0;
  left: -10%;
  width: 120%;
  transform: rotate(-1.5deg);
  opacity: 0.18;
}
.price-teaser-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--sp-5);
}
.price-teaser-card {
  display: flex;
  flex-direction: column;
  padding: var(--sp-6);
}
.price-teaser-card.is-popular {
  border-color: var(--c-accent);
  box-shadow: var(--sh-glow);
}
.price-teaser-duration {
  align-self: flex-start;
  padding: 2px var(--sp-3);
  margin-bottom: var(--sp-4);
  border-radius: var(--r-full);
  background: var(--c-accent-dim);
  color: var(--c-accent-bright);
  font-size: var(--fs-xs);
  font-weight: var(--fw-semibold);
}
.price-teaser-amount {
  display: flex;
  align-items: baseline;
  gap: var(--sp-2);
  margin-bottom: var(--sp-4);
}
.price-teaser-cur {
  font-family: var(--font-display);
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--c-text-muted);
}
.price-teaser-num {
  font-family: var(--font-display);
  font-size: var(--fs-4xl);
  font-weight: var(--fw-extrabold);
  color: var(--c-text);
  line-height: 1;
  letter-spacing: -0.02em;
}
.price-teaser-desc {
  font-size: var(--fs-sm);
