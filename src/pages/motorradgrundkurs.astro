---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTASection from '@components/CTASection.astro';
import { company, reviews } from '@data/site';

const phoneLink = company.phone.replace(/\s/g, '');

// ── Was du im Grundkurs lernst (Fahrtechnik-Module) ──────────────────────────
const skills = [
  { title: 'Bremsen', text: 'Gefahr- und Standbremsung, kombinierte Bremsung – kontrolliert bis zum Stillstand.' },
  { title: 'Kurvenfahren', text: 'Linienwahl, Schräglage und Geschwindigkeits­kontrolle in der Kurve.' },
  { title: 'Anfahren', text: 'Sauberes Anfahren am Berg und im Gefälle, ohne Abwürgen.' },
  { title: 'Ausweichen', text: 'Ausweichen vor Hindernissen und kontrollierter Slalom.' },
  { title: 'Balance & Langsamfahrt', text: 'Gleichgewicht im Schritttempo – die Basis für jedes Manöver.' },
  { title: 'Blicktechnik', text: 'Vorausschauend schauen und richtig blicken – sicher im Verkehr.' },
];

// ── Ablauf des Grundkurses ───────────────────────────────────────────────────
const steps = [
  {
    title: 'Anmeldung & Termine',
    text: 'Du meldest dich an, wir koordinieren die Kurstermine. Der Grundkurs umfasst insgesamt 12 Stunden, aufgeteilt auf mehrere Teile.',
  },
  {
    title: 'Theorie & Vorbereitung',
    text: 'Maschine kennenlernen, richtige Sitzposition, Bedienung und die Grundlagen, bevor es aufs Gelände geht.',
  },
  {
    title: 'Fahrtechnik auf dem Gelände',
    text: 'Auf abgesperrtem Gelände übst du Bremsen, Kurven, Slalom und Langsamfahrt – Schritt für Schritt, in deinem Tempo.',
  },
  {
    title: 'Bestätigung & nächster Schritt',
    text: 'Nach erfolgreichem Abschluss erhältst du die Kursbestätigung – die Basis für deinen weiteren Weg zur Kategorie A.',
  },
];

// ── Voraussetzungen / was du mitbringst ──────────────────────────────────────
const requirements = [
  'Gültiger Lernfahrausweis der Kategorie A oder A1',
  'Eigenes oder gemietetes Motorrad der passenden Kategorie',
  'Vollständige Schutz­ausrüstung: Helm, Handschuhe, feste Kleidung & Schuhe',
  'Motivation und Bereitschaft, Schritt für Schritt zu lernen',
];

// ── JSON-LD ──────────────────────────────────────────────────────────────────
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Motorradgrundkurs – Basis-Fahrtechnik',
  serviceType: 'Motorradgrundkurs',
  description:
    'Motorradgrundkurs bei der Fahrschule Antonio Marino: 12 Stunden Basis-Fahrtechnik auf geschlossenem Gelände – Pflichtkurs für die Kategorie A.',
  provider: { '@id': `${company.url}/#organization` },
  areaServed: { '@type': 'Country', name: 'Schweiz' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'CHF',
    availability: 'https://schema.org/InStock',
    url: `${company.url}/kontakt`,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: reviews.ratingValue,
    reviewCount: reviews.reviewCount,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: company.url },
    { '@type': 'ListItem', position: 2, name: 'Leistungen', item: `${company.url}/leistungen` },
    { '@type': 'ListItem', position: 3, name: 'Motorradgrundkurs', item: `${company.url}/motorradgrundkurs` },
  ],
};
---

<BaseLayout
  title="Motorradgrundkurs | Antonio Marino"
  description="Motorradgrundkurs bei der Fahrschule Antonio Marino. 12 Stunden Basis-Fahrtechnik auf geschlossenem Gelände für Motorrad-Lernfahrende."
  schema={[serviceSchema, breadcrumbSchema]}
>
  <Hero
    eyebrow="Motorradgrundkurs"
    title="Auf zwei Rädern"
    titleHighlight="unterwegs."
    subtitle="12 Stunden Basis-Fahrtechnik für Motorrad-Lernfahrende. Der Grundkurs ist Pflicht für die Kategorie A – und die Basis für sicheres Fahren."
    showCTA={false}
  />

  <!-- ══ INTRO ══════════════════════════════════════════════════════════ -->
  <section class="section intro-section" aria-labelledby="intro-heading">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-copy">
          <p class="eyebrow" data-anim="fade-up">Pflichtkurs Kategorie A</p>
          <h2 id="intro-heading" data-anim="fade-up" data-anim-delay="0.08">
            Die Basis für sicheres Motorradfahren
          </h2>
          <p class="intro-lead" data-anim="fade-up" data-anim-delay="0.16">
            Der Motorradgrundkurs ist Pflicht für alle, die den Führerausweis der
            Kategorie A machen wollen. In 12 Stunden lernst du die Grundlagen der
            Motorrad­fahrtechnik – sicher und kontrolliert auf einem geschlossenen
            Gelände, fernab vom Verkehr.
          </p>
          <p class="intro-text" data-anim="fade-up" data-anim-delay="0.22">
            Schritt für Schritt baust du Vertrauen zur Maschine auf: vom richtigen
            Bremsen über die saubere Kurventechnik bis zur Balance im Schritttempo.
            So gehst du sicher in den weiteren Weg zum Töff-Führerschein.
          </p>
        </div>

        <ul class="intro-stats" role="list">
          <li class="intro-stat" data-anim="fade-up" data-anim-delay="0.10">
            <span class="is-num" data-count="12">12</span>
            <span class="is-label">Stunden Basis-Fahrtechnik</span>
          </li>
          <li class="intro-stat" data-anim="fade-up" data-anim-delay="0.16">
            <span class="is-num" data-count={reviews.ratingValue} data-count-decimals="1" data-count-suffix="/5">{reviews.ratingValue}/5</span>
            <span class="is-label">Google-Bewertung aus {reviews.reviewCount} Rezensionen</span>
          </li>
          <li class="intro-stat" data-anim="fade-up" data-anim-delay="0.22">
            <span class="is-num" data-count="10" data-count-suffix="+">10+</span>
            <span class="is-label">Jahre Erfahrung als Fahrlehrer</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ SKILLS / WAS DU LERNST ═════════════════════════════════════════ -->
  <section class="section skills-section" aria-labelledby="skills-heading">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow" data-anim="fade-up">Im Grundkurs</p>
        <h2 id="skills-heading" data-anim="fade-up" data-anim-delay="0.08">
          Das lernst du auf dem Gelände
        </h2>
      </div>

      <ul class="skills-grid" role="list">
        {skills.map((skill, i) => (
          <li class="skill-card" data-anim="fade-up" data-anim-delay={(0.05 * i).toFixed(2)}>
            <span class="skill-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="17" r="3"/><circle cx="19" cy="17" r="3"/><path d="M8 17h6l3-6m0 0h-4l-1.5-3M17 11l2-3"/></svg>
            </span>
            <h3 class="skill-title">{skill.title}</h3>
            <p class="skill-text">{skill.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══ ABLAUF ═════════════════════════════════════════════════════════ -->
  <section class="section ablauf-section" aria-labelledby="ablauf-heading">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow" data-anim="fade-up">So läuft's ab</p>
        <h2 id="ablauf-heading" data-anim="fade-up" data-anim-delay="0.08">
          Dein Grundkurs – Schritt für Schritt
        </h2>
      </div>

      <ol class="steps" role="list">
        {steps.map((step, i) => (
          <li class="step" data-anim="fade-up" data-anim-delay={(0.07 * i).toFixed(2)}>
            <span class="step-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="step-body">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-text">{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ══ VORAUSSETZUNGEN + PREIS AUF ANFRAGE ════════════════════════════ -->
  <section class="section req-section" aria-labelledby="req-heading">
    <div class="container">
      <div class="req-grid">
        <div class="req-copy" data-anim="slide-right">
          <p class="eyebrow">Was du mitbringst</p>
          <h2 id="req-heading">Voraussetzungen</h2>
          <ul class="req-list" role="list">
            {requirements.map((r) => (
              <li class="req-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>

        <aside class="price-card glass-strong" data-anim="scale-in" aria-label="Preis auf Anfrage">
          <span class="pc-glow" aria-hidden="true"></span>
          <p class="pc-eyebrow">Motorradgrundkurs · 12 Std</p>
          <p class="pc-price">Preis auf Anfrage</p>
          <p class="pc-note">
            Melde dich für den nächsten Grundkurs – wir nennen dir die aktuellen
            Termine und einen fairen Preis. Sprich uns einfach an, wir beraten
            dich gerne persönlich.
          </p>
          <a href="/kontakt" class="btn btn-cta btn-lg btn-magnetic pc-btn">
            Jetzt anfragen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={`tel:${phoneLink}`} class="pc-phone">{company.phone}</a>
        </aside>
      </div>
    </div>
  </section>

  <CTASection
    title="Bereit für den Töff-Grundkurs?"
    subtitle="Frag die nächsten Kurstermine an – per Telefon, WhatsApp oder Formular. Antwort innerhalb von 24 Stunden."
  />
</BaseLayout>

<style>
/* ── Abschnitts-Kopf ─────────────────────────────────────────────── */
.section-head {
  max-width: 720px;
  margin: 0 auto var(--sp-12);
  text-align: center;
}
.section-head .eyebrow { justify-content: center; }
.section-head h2 { margin-bottom: var(--sp-4); }

/* ── Intro ───────────────────────────────────────────────────────── */
.intro-grid {
  display: grid;
  grid-template-columns: 1.25fr 0.75fr;
  gap: var(--sp-12);
  align-items: center;
}
.intro-copy h2 { margin-bottom: var(--sp-5); }
.intro-lead {
  font-size: var(--fs-lg);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
  margin-bottom: var(--sp-5);
}
.intro-text {
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}
.intro-stats {
  display: flex;
  flex-direction: column;
  gap: var(--sp-5);
}
.intro-stat {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  padding-left: var(--sp-5);
  border-left: 2px solid var(--c-border-gold);
}
.is-num {
  font-family: var(--font-display);
  font-size: var(--fs-3xl);
  font-weight: var(--fw-extrabold);
  color: var(--c-accent);
  line-height: 1;
}
.is-label {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-normal);
}

/* ── Skills-Grid ─────────────────────────────────────────────────── */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-5);
}
.skill-card {
  position: relative;
  padding: var(--sp-6);
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: transform var(--t-base), border-color var(--t-base), box-shadow var(--t-base);
}
.skill-card::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: var(--grad-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--t-base);
}
.skill-card:hover {
  transform: translateY(-5px);
  border-color: var(--c-border-gold);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
}
.skill-card:hover::before { transform: scaleX(1); }
.skill-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: var(--r-md);
  background: color-mix(in srgb, var(--c-accent) 14%, transparent);
  color: var(--c-accent);
  margin-bottom: var(--sp-4);
  transition: transform var(--t-base), background var(--t-base), color var(--t-base);
}
.skill-card:hover .skill-icon {
  transform: scale(1.08) rotate(-3deg);
  background: var(--c-accent);
  color: var(--c-bg);
}
.skill-title {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  margin-bottom: var(--sp-2);
}
.skill-text {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}

/* ── Ablauf / Steps ──────────────────────────────────────────────── */
.ablauf-section {
  background: var(--c-bg-elevated);
  border-block: 1px solid var(--c-border);
}
.steps {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--sp-5);
}
.step {
  position: relative;
  display: flex;
  gap: var(--sp-5);
  padding: var(--sp-6);
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: transform var(--t-base), border-color var(--t-base), box-shadow var(--t-base);
}
.step::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: var(--grad-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--t-base);
}
.step:hover {
  transform: translateY(-5px);
  border-color: var(--c-border-gold);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
}
.step:hover::before { transform: scaleX(1); }
.step-num {
  flex-shrink: 0;
  font-family: var(--font-display);
  font-size: var(--fs-4xl);
  font-weight: var(--fw-extrabold);
  line-height: 1;
  color: var(--c-accent);
  opacity: 0.85;
  text-shadow: 0 0 22px var(--c-accent-dim);
}
.step-title {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  margin-bottom: var(--sp-2);
}
.step-text {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}

/* ── Voraussetzungen + Preis ─────────────────────────────────────── */
.req-section {
  background: var(--c-bg-elevated);
  border-block: 1px solid var(--c-border);
}
.req-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: var(--sp-12);
  align-items: center;
}
.req-copy h2 { margin-bottom: var(--sp-6); }
.req-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}
.req-item {
  display: flex;
  align-items: flex-start;
  gap: var(--sp-3);
  color: var(--c-text);
  line-height: var(--lh-normal);
}
.req-item svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--c-accent);
}

.price-card {
  position: relative;
  padding: var(--sp-8) var(--sp-7);
  border: 1px solid var(--c-border-gold);
  border-radius: var(--r-xl);
  text-align: center;
  overflow: hidden;
  box-shadow: var(--sh-glow);
}
.pc-glow {
  position: absolute;
  top: -160px;
  left: 50%;
  transform: translateX(-50%);
  width: 440px;
  max-width: 130%;
  height: 320px;
  background: radial-gradient(ellipse at center, var(--c-accent-glow), transparent 68%);
  pointer-events: none;
}
.pc-eyebrow {
  position: relative;
  font-family: var(--font-display);
  font-size: var(--fs-xs);
  font-weight: var(--fw-bold);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--c-accent);
  margin-bottom: var(--sp-3);
}
.pc-price {
  position: relative;
  font-family: var(--font-display);
  font-size: var(--fs-3xl);
  font-weight: var(--fw-extrabold);
  color: var(--c-text);
  line-height: 1.1;
  margin-bottom: var(--sp-4);
}
.pc-note {
  position: relative;
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
  margin-bottom: var(--sp-6);
}
.pc-btn {
  position: relative;
  width: 100%;
  justify-content: center;
  margin-bottom: var(--sp-3);
}
.pc-phone {
  position: relative;
  display: inline-block;
  font-family: var(--font-display);
  font-weight: var(--fw-semibold);
  color: var(--c-accent);
}
.pc-phone:hover { color: var(--c-accent-bright); }

/* ── Responsive ──────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .skills-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .intro-grid,
  .req-grid {
    grid-template-columns: 1fr;
    gap: var(--sp-8);
  }
  .intro-stats { flex-direction: row; flex-wrap: wrap; }
  .intro-stat { flex: 1 1 160px; }
}
@media (max-width: 680px) {
  .skills-grid,
  .steps {
    grid-template-columns: 1fr;
  }
  .intro-stats { flex-direction: column; }
}
</style>
