---
import BaseLayout from '@layouts/BaseLayout.astro';
import { services, company, priceList, onRequestList } from '@data/site';
import CTASection from '@components/CTASection.astro';
import FAQ from '@components/FAQ.astro';

// Service icons — proper SVG paths, no broken icons
const icons: Record<string, string> = {
  car: '<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9L18.4 11l-2.5-3.3c-.4-.5-1-.7-1.6-.7H7.7c-.6 0-1.2.3-1.6.8L4 11l-1.5.1C1.7 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  'first-aid': '<path d="M8 2v4M4 6h16v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6z"/><path d="M12 10v6M9 13h6"/>',
  check: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  motorcycle: '<path d="M3 17a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14-4l-4-4M5 13l2-5h4l1 3h5"/><circle cx="19" cy="17" r="2"/><path d="M14 17h3"/><path d="M10 7l1-2h3"/>',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: company.url },
    { '@type': 'ListItem', position: 2, name: 'Leistungen', item: `${company.url}/leistungen` },
  ],
};

const faqItems = [
  { question: 'Was kostet eine Fahrstunde?', answer: 'Eine einzelne Fahrstunde (45 Min) kostet ab CHF 89.-. Beliebt ist die 75-Minuten-Lektion für schnelleren Fortschritt. Mit Paketen sparst du bis zu CHF 572.' },
  { question: 'Bietet ihr Pakete an?', answer: 'Ja! Vom 10-er Abo (CHF 930.-) bis zum Intensivkurs L mit 44 Lektionen (CHF 3\'960.-) gibt es für jedes Budget und jedes Tempo das passende Paket.' },
  { question: 'Was ist im Preis inbegriffen?', answer: 'Alle Preise beinhalten den Fahrlehrer, das Fahrzeug und — nach Möglichkeit — den Abholservice. Einmalig fällt ab der 2. Buchung eine Administrationsgebühr von CHF 130.- an.' },
  { question: 'In welchen Sprachen wird unterrichtet?', answer: `Auf ${company.languages.join(', ')}.` },
];
---

<BaseLayout
  title="Leistungen & Preise | Antonio Marino"
  description="Alle Leistungen der Fahrschule Antonio Marino: Fahrstunden ab 89.-, VKU, Nothelferkurs, Prüfungsvorbereitung, Kontrollfahrt und Motorradgrundkurs. Transparente Preise und Pakete."
  schema={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="section hero-sm">
    <div class="container">
      <p class="eyebrow" data-animate="fade-up">Leistungen & Preise</p>
      <h1 data-animate="fade-up" style="margin-bottom: 1.5rem;">
        Alles für deinen<br><span class="gradient-text">Führerschein.</span>
      </h1>
      <p class="text-muted" data-animate="fade-up" style="font-size: 1.25rem; max-width: 600px;">
        Vom Nothelferkurs bis zur Prüfung — ein Ansprechpartner, faire Preise, keine versteckten Kosten.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="services-grid" data-animate="stagger">
        {services.map((service) => (
          <a href={`/${service.slug}`} class="service-card" data-stagger-item>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[service.icon] || icons.car} />
            </div>
            <h3>{service.name}</h3>
            <p>{service.description}</p>
            {service.duration && <span class="service-duration">⏱ {service.duration}</span>}
            <span class="service-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Preise -->
  <section class="section pricing-section">
    <div class="container">
      <p class="eyebrow" data-animate="fade-up">Preise</p>
      <h2 data-animate="fade-up" style="margin-bottom: 1rem;">Transparente Preise</h2>
      <p class="text-muted" data-animate="fade-up" style="font-size: 1.1rem; margin-bottom: 3rem; max-width: 600px;">
        Einzelne Fahrstunden oder Sparpakete — du entscheidest. Alle Preise inkl. Fahrlehrer, Fahrzeug und Abholservice.
      </p>

      <!-- Einzellesson cards -->
      <div class="price-cards" data-animate="stagger">
        {priceList.filter(p => !p.priceOnRequest).map((item) => (
          <div class="price-card" data-stagger-item>
            <h4>{item.name}</h4>
            <p class="price-desc">{item.description}</p>
            <p class="price-value">{item.price}</p>
          </div>
        ))}
      </div>

      <!-- Auf Anfrage -->
      <div class="on-request-section" data-animate="fade-up">
        <h3 style="margin-bottom: 1.5rem;">Kurse auf Anfrage</h3>
        <div class="on-request-grid">
          {onRequestList.map((item) => (
            <div class="on-request-card">
              <h4>{item.name}</h4>
              <p>{item.description}</p>
              <a href="/kontakt" class="btn btn-ghost btn-sm" style="margin-top: 12px;">Preis anfragen</a>
            </div>
          ))}
        </div>
      </div>

      <p class="price-note" data-animate="fade-up">
        ⚠️ Einmalige Administrationsgebühr von CHF 130.- ab der 2. Buchung. Treffpunkt: Bahnhof Rapperswil oder nach Vereinbarung.
      </p>
    </div>
  </section>

  <CTASection />

  <FAQ items={faqItems} title="Häufige Fragen zu Preisen & Leistungen" />
</BaseLayout>

<style>
.hero-sm { padding-top: calc(var(--header-h) + 4rem); }
.services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }

.service-card {
  display: block; background: var(--c-surface); border: 1px solid var(--c-border);
  border-radius: var(--r-lg); padding: 2rem; transition: all 0.3s; position: relative; overflow: hidden; height: 100%;
}
.service-card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at top right, var(--c-red-glow), transparent 60%);
  opacity: 0; transition: opacity 0.3s;
}
.service-card:hover { border-color: var(--c-red); transform: translateY(-4px); box-shadow: var(--sh-card); }
.service-card:hover::before { opacity: 0.5; }

.service-icon {
  width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;
  background: rgba(230, 57, 70, 0.15); border-radius: var(--r-md);
  color: var(--c-red-bright); margin-bottom: 1.5rem; transition: all 0.3s;
}
.service-card:hover .service-icon { background: var(--c-red); color: white; transform: scale(1.1); }

.service-card h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
.service-card p { font-size: 0.9rem; color: var(--c-text-muted); margin-bottom: 1rem; }
.service-duration { display: inline-block; font-size: 0.75rem; padding: 4px 12px; background: rgba(255,255,255,0.05); border-radius: 99px; color: var(--c-text-dim); }
.service-arrow { position: absolute; bottom: 1.5rem; right: 1.5rem; color: var(--c-red-bright); opacity: 0; transform: translateX(-10px); transition: all 0.3s; }
.service-card:hover .service-arrow { opacity: 1; transform: translateX(0); }

.pricing-section { background: var(--c-bg-2); }
.price-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 4rem; }
.price-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-md); padding: 1.5rem; transition: all 0.3s; }
.price-card:hover { border-color: var(--c-amber); }
.price-card h4 { font-size: 1rem; margin-bottom: 0.5rem; }
.price-desc { font-size: 0.85rem; color: var(--c-text-muted); margin-bottom: 1rem; min-height: 2.5em; }
.price-value { font-family: var(--font-display); font-size: 1.75rem; font-weight: 800; color: var(--c-amber); }

.on-request-section { margin-top: 3rem; }
.on-request-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
.on-request-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-md); padding: 1.5rem; }
.on-request-card h4 { font-size: 1rem; margin-bottom: 0.5rem; }
.on-request-card p { font-size: 0.85rem; color: var(--c-text-muted); }

.price-note { margin-top: 2rem; padding: 1rem 1.5rem; background: rgba(255, 182, 39, 0.08); border: 1px solid rgba(255, 182, 39, 0.2); border-radius: var(--r-md); font-size: 0.85rem; color: var(--c-text-muted); }

@media (max-width: 768px) {
  .services-grid { grid-template-columns: 1fr; }
  .price-cards { grid-template-columns: 1fr; }
  .on-request-grid { grid-template-columns: 1fr; }
}
</style>
