---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTASection from '@components/CTASection.astro';
import { company } from '@data/site';
---

<BaseLayout
  title="Preise & Pakete | Antonio Marino"
  description={`Preise und Pakete der Fahrschule Antonio Marino. Transparente Kosten für Fahrstunden, VKU und Nothelferkurs. Jetzt anfragen: ${company.phone}.`}
>
  <Hero eyebrow="Preise" title="Faire Preise," titleHighlight="klare Pakete." subtitle="Transparente Kosten ohne versteckte Gebühren. Frag uns nach deinem persönlichen Paket." backgroundVariant="minimal" />

  <section class="section">
    <div class="container">
      <div class="price-grid">
        <div class="price-card reveal">
          <h3>Fahrstunde (60 Min)</h3>
          <p class="price-note">Individueller Unterricht mit Antonio</p>
          <p class="price-on-request">Auf Anfrage</p>
          <ul class="price-features">
            <li>60 oder 90 Minuten</li>
            <li>Abholservice inklusive</li>
            <li>5 Sprachen zur Auswahl</li>
            <li>Prüfungsrouten-Training</li>
          </ul>
          <a href="/kontakt" class="btn btn-ghost" style="width:100%;">Anfragen</a>
        </div>

        <div class="price-card price-featured reveal reveal-delay-1">
          <div class="price-badge">Beliebt</div>
          <h3>Anfänger-Paket</h3>
          <p class="price-note">Nothelferkurs + VKU + erste Fahrstunden</p>
          <p class="price-on-request">Auf Anfrage</p>
          <ul class="price-features">
            <li>10 Std Nothelferkurs</li>
            <li>8 Std Verkehrskundeunterricht</li>
            <li>5 Fahrstunden (á 60 Min)</li>
            <li>Persönliche Betreuung</li>
            <li>Alle Materialien inklusive</li>
          </ul>
          <a href="/kontakt" class="btn btn-primary" style="width:100%;">Paket buchen</a>
        </div>

        <div class="price-card reveal reveal-delay-2">
          <h3>Prüfungsvorbereitung</h3>
          <p class="price-note">Gezieltes Training vor der Prüfung</p>
          <p class="price-on-request">Auf Anfrage</p>
          <ul class="price-features">
            <li>Prüfungsrouten fahren</li>
            <li>Simulation der Prüfung</li>
            <li>Feedback & Tipps</li>
            <li>Bis du bereit bist</li>
          </ul>
          <a href="/kontakt" class="btn btn-ghost" style="width:100%;">Anfragen</a>
        </div>
      </div>

      <p class="price-disclaimer reveal reveal-delay-3">
        Alle Preise auf Anfrage. Ruf an unter <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="text-accent">{company.phone}</a> oder schreibe uns über das <a href="/kontakt" class="text-accent">Kontaktformular</a>.
      </p>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
.price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-5); max-width: 1000px; margin-inline: auto; }
.price-card { background: var(--grad-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: var(--sp-6); position: relative; transition: all var(--t-base); }
.price-card:hover { border-color: var(--c-accent-dim); transform: translateY(-4px); }
.price-featured { border-color: var(--c-accent); box-shadow: var(--sh-glow); }
.price-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--grad-accent); color: var(--c-bg); padding: var(--sp-1) var(--sp-4); border-radius: var(--r-full); font-size: var(--fs-xs); font-weight: var(--fw-bold); text-transform: uppercase; letter-spacing: 0.1em; }
.price-card h3 { font-size: var(--fs-xl); margin-bottom: var(--sp-1); }
.price-note { font-size: var(--fs-sm); color: var(--c-text-muted); margin-bottom: var(--sp-4); }
.price-on-request { font-family: var(--font-display); font-size: var(--fs-3xl); font-weight: var(--fw-extrabold); color: var(--c-accent); margin-bottom: var(--sp-5); }
.price-features { display: flex; flex-direction: column; gap: var(--sp-3); margin-bottom: var(--sp-6); }
.price-features li { display: flex; gap: var(--sp-2); font-size: var(--fs-sm); color: var(--c-text-muted); }
.price-features li::before { content: '✓'; color: var(--c-accent); font-weight: bold; }
.price-disclaimer { text-align: center; margin-top: var(--sp-8); color: var(--c-text-muted); }
@media (max-width: 768px) { .price-grid { grid-template-columns: 1fr; } }
</style>
