---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTASection from '@components/CTASection.astro';
import FAQ from '@components/FAQ.astro';
import { company } from '@data/site';

const phoneLink = company.phone.replace(/\s/g, '');

// ── Kurs-Inhalte: Ablauf der 10 Stunden Erste Hilfe am Unfallort ────────────
const steps = [
  {
    num: '01',
    accent: 'gold',
    title: 'Unfallstelle absichern',
    desc: 'Richtig reagieren, wenn jeder Moment zählt: Gefahrenzone erkennen, Warndreieck stellen, dich und andere schützen.',
  },
  {
    num: '02',
    accent: 'teal',
    title: 'Notruf & Alarmierung',
    desc: 'Die Notrufnummern, die richtigen Angaben am Telefon und wie du gezielt Hilfe organisierst, bis der Rettungsdienst eintrifft.',
  },
  {
    num: '03',
    accent: 'red',
    title: 'Retten & lagern',
    desc: 'Verletzte aus der Gefahrenzone bringen, die stabile Seitenlage und der Umgang mit bewusstlosen Personen.',
  },
  {
    num: '04',
    accent: 'gold',
    title: 'Lebensrettende Massnahmen',
    desc: 'Herz-Lungen-Wiederbelebung, Herzdruckmassage und der Einsatz eines Defibrillators – an Übungspuppen trainiert.',
  },
  {
    num: '05',
    accent: 'teal',
    title: 'Wunden & typische Verletzungen',
    desc: 'Blutungen stoppen, Wunden versorgen und das richtige Verhalten bei Verletzungen im Strassenverkehr.',
  },
];

const voraussetzungen = [
  { title: 'Keine Vorkenntnisse nötig', desc: 'Du musst nichts mitbringen ausser Motivation – wir bringen dir alles bei, von Grund auf.' },
  { title: 'Vor dem Lernfahrausweis', desc: 'Der Nothelferkurs muss absolviert sein, bevor du den Lernfahrausweis beantragen kannst.' },
  { title: 'Für jedes Alter geeignet', desc: 'Ob für Auto, Motorrad oder Roller – der Nothilfekurs ist der erste Schritt für alle Kategorien.' },
];

const faqItems = [
  { question: 'Was ist der Nothelferkurs?', answer: 'Ein 10-stündiger Pflichtkurs, der dich in Erster Hilfe am Unfallort ausbildet. Er muss vor dem Lernfahrausweis absolviert werden.' },
  { question: 'Wie lange ist das Nothelfer-Zertifikat gültig?', answer: 'Das Zertifikat ist 6 Jahre gültig und wird von allen Strassenverkehrsämtern in der Schweiz anerkannt.' },
  { question: 'Brauche ich den Kurs, wenn ich schon einen Erste-Hilfe-Kurs gemacht habe?', answer: 'Der Nothelferkurs für den Führerausweis muss spezifisch als "Nothilfekurs" zertifiziert sein. Ein allgemeiner Erste-Hilfe-Kurs reicht in der Regel nicht.' },
  { question: 'Wie ist der Kurs aufgeteilt?', answer: 'Die 10 Stunden werden in der Regel auf zwei bis drei Termine verteilt – praxisnah, mit viel Üben an Puppen und Simulatoren statt trockener Theorie.' },
  { question: 'Wie viel kostet der Nothelferkurs?', answer: `Den aktuellen Preis erfährst du direkt bei Antonio unter ${company.phone} oder über das Kontaktformular. Kursunterlagen und Bestätigung sind inklusive.` },
];

// ── JSON-LD ──────────────────────────────────────────────────────────────
const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Nothelferkurs (Nothilfekurs)',
  description: 'Obligatorischer 10-stündiger Nothelferkurs (Erste Hilfe am Unfallort) als Voraussetzung für den Lernfahrausweis. Zertifiziert, praxisnah, in kleinen Gruppen.',
  provider: { '@id': `${company.url}/#organization` },
  inLanguage: ['de', 'en', 'it', 'fr', 'es'],
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'onsite',
    courseWorkload: 'PT10H',
    location: { '@type': 'Country', name: 'Schweiz' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: company.url },
    { '@type': 'ListItem', position: 2, name: 'Leistungen', item: `${company.url}/leistungen` },
    { '@type': 'ListItem', position: 3, name: 'Nothelferkurs', item: `${company.url}/nothelferkurs` },
  ],
};
---

<BaseLayout
  title="Nothelferkurs | Fahrschule Antonio Marino"
  description="Nothelferkurs (Nothilfekurs) bei der Fahrschule Antonio Marino. 10 Stunden Pflichtkurs für den Führerausweis. Zertifiziert, praxisnah, in kleinen Gruppen – jetzt anfragen!"
  schema={[courseSchema, breadcrumbSchema]}
>
  <Hero
    eyebrow="Nothelferkurs · 10 Stunden Pflicht"
    title="Erste Hilfe,"
    titleHighlight="die zählt."
    subtitle="10 Stunden, die Leben retten können. Der Pflichtkurs für deinen Führerausweis – praxisnah, intensiv und mit echten Übungen statt trockener Theorie."
  />

  <!-- ══ INTRO · Was ist der Kurs / für wen ══ -->
  <section class="section nh-intro" aria-labelledby="intro-heading">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-copy">
          <p class="eyebrow" data-anim="fade-up">Was ist der Nothelferkurs?</p>
          <h2 id="intro-heading" data-anim="fade-up" data-anim-delay="0.08">
            Dein erster Schritt zum Führerausweis
          </h2>
          <p class="intro-lead" data-anim="fade-up" data-anim-delay="0.16">
            Bevor du den Lernfahrausweis beantragen kannst, musst du einen
            Nothelferkurs (auch Nothilfekurs) absolvieren. Dieser
            <strong>10-stündige</strong> Kurs vermittelt dir die Grundlagen der
            Ersten Hilfe am Unfallort.
          </p>
          <p class="intro-text" data-anim="fade-up" data-anim-delay="0.22">
            Du lernst, wie du bei einem Verkehrsunfall richtig reagierst: absichern,
            aus der Gefahrenzone retten, stabile Seitenlage, Herzdruckmassage und
            den Notruf absetzen. Praxisorientiert, intensiv und mit echten
            Fallbeispielen – damit du im Ernstfall handeln kannst.
          </p>

          <div class="intro-actions" data-anim="fade-up" data-anim-delay="0.28">
            <a href="/kontakt" class="btn btn-primary btn-lg btn-magnetic">
              Kursplatz anfragen
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={`tel:${phoneLink}`} class="btn btn-ghost btn-lg btn-magnetic">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {company.phone}
            </a>
          </div>
        </div>

        <!-- Eckdaten-Karten -->
        <ul class="fact-cards" role="list">
          <li class="fact-card" data-accent="red" data-anim="fade-up" data-anim-delay="0.10">
            <span class="fact-num"><span data-count="10">10</span></span>
            <span class="fact-label">Stunden Praxis</span>
            <span class="fact-note">auf 2–3 Termine verteilt</span>
          </li>
          <li class="fact-card" data-accent="teal" data-anim="fade-up" data-anim-delay="0.18">
            <span class="fact-num"><span data-count="6">6</span></span>
            <span class="fact-label">Jahre gültig</span>
            <span class="fact-note">schweizweit anerkannt</span>
          </li>
          <li class="fact-card" data-accent="gold" data-anim="fade-up" data-anim-delay="0.26">
            <span class="fact-num fact-num-text">1.</span>
            <span class="fact-label">Schritt zum Ausweis</span>
            <span class="fact-note">vor dem Lernfahrausweis</span>
          </li>
          <li class="fact-card" data-accent="red" data-anim="fade-up" data-anim-delay="0.34">
            <span class="fact-num fact-num-text">inkl.</span>
            <span class="fact-label">Unterlagen & Zertifikat</span>
            <span class="fact-note">offizielle Bestätigung</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ INHALTE / ABLAUF · die 5 Praxisblöcke ══ -->
  <section class="section step-section" aria-labelledby="step-heading">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow" data-anim="fade-up">Inhalte & Ablauf</p>
        <h2 id="step-heading" data-anim="fade-up" data-anim-delay="0.08">
          10 Stunden, die du nie vergisst
        </h2>
        <p class="section-lead" data-anim="fade-up" data-anim-delay="0.16">
          Der Nothelferkurs ist praxisorientiert aufgebaut. Du übst echte
          Handgriffe an Puppen und Simulatoren – damit du im Ernstfall nicht
          überlegen musst, sondern handelst.
        </p>
      </div>

      <ol class="step-list" role="list">
        {steps.map((s, i) => (
          <li
            class="step-card"
            data-accent={s.accent}
            data-anim="fade-up"
            data-anim-delay={(0.06 * i).toFixed(2)}
          >
            <span class="step-index" aria-hidden="true">{s.num}</span>
            <div class="step-body">
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
            <span class="step-line" aria-hidden="true"></span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ══ VORAUSSETZUNGEN ══ -->
  <section class="section req-section" aria-labelledby="req-heading">
    <div class="container">
      <div class="req-inner">
        <div class="req-copy" data-anim="slide-right">
          <p class="eyebrow">Voraussetzungen</p>
          <h2 id="req-heading">Wer kann teilnehmen?</h2>
          <p class="req-lead">
            Der Nothelferkurs ist der Startpunkt deiner Fahrausbildung. Die gute
            Nachricht: Du brauchst praktisch nichts mitzubringen – ausser dem Willen,
            im Notfall helfen zu können.
          </p>
        </div>

        <ul class="req-list" role="list">
          {voraussetzungen.map((r, i) => (
            <li class="req-item" data-anim="fade-up" data-anim-delay={(0.08 * i).toFixed(2)}>
              <span class="req-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <div>
                <h3 class="req-title">{r.title}</h3>
                <p class="req-desc">{r.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ PREIS AUF ANFRAGE ══ -->
  <section class="section price-section" aria-labelledby="price-heading">
    <div class="container container-narrow">
      <div class="price-card" data-anim="scale-in">
        <span class="price-glow" data-parallax data-parallax-speed="0.08" aria-hidden="true"></span>
        <div class="price-content">
          <p class="eyebrow">Preis auf Anfrage</p>
          <h2 id="price-heading">Inklusive Unterlagen & Zertifikat</h2>
          <p class="price-lead">
            Für den Nothelferkurs erhältst du deinen persönlichen Preis direkt von
            Antonio – inklusive aller Kursunterlagen und der offiziellen,
            schweizweit anerkannten Bestätigung. Frag jetzt unverbindlich an.
          </p>
          <div class="price-actions">
            <a href="/kontakt" class="btn btn-cta btn-lg btn-magnetic">
              Jetzt anfragen
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={`tel:${phoneLink}`} class="btn btn-ghost btn-lg btn-magnetic">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {company.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Nothelferkurs buchen"
    subtitle="Sichere dir deinen Platz und mach den ersten Schritt zum Führerausweis. Antonio antwortet innerhalb von 24 Stunden."
  />

  <FAQ items={faqItems} title="Häufige Fragen zum Nothelferkurs" />
</BaseLayout>

<style>
/* ── Abschnitts-Kopf (gleich wie /leistungen + VKU) ──────────────── */
.section-head {
  max-width: 720px;
  margin: 0 auto var(--sp-12);
  text-align: center;
}
.section-head .eyebrow { justify-content: center; }
.section-head h2 { margin-bottom: var(--sp-4); }
.section-lead {
  font-size: var(--fs-lg);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}

/* ── INTRO ───────────────────────────────────────────────────────── */
.intro-grid {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: var(--sp-12);
  align-items: center;
}
.intro-copy h2 { margin-bottom: var(--sp-4); }
.intro-lead {
  font-size: var(--fs-lg);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
  margin-bottom: var(--sp-4);
}
.intro-lead strong { color: var(--c-accent); }
.intro-text {
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
  margin-bottom: var(--sp-6);
}
.intro-actions {
  display: flex;
  gap: var(--sp-4);
  flex-wrap: wrap;
}

/* Eckdaten-Karten */
.fact-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--sp-4);
}
.fact-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  padding: var(--sp-6) var(--sp-5);
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: transform var(--t-base), border-color var(--t-base);
}
.fact-card::before {
  content: '';
  position: absolute;
  inset: 0 auto 0 0;
  width: 3px;
  background: var(--fc-accent);
}
.fact-card:hover {
  transform: translateY(-4px);
  border-color: var(--fc-border);
}
.fact-card[data-accent='gold'] { --fc-accent: var(--c-accent); --fc-border: var(--c-border-gold); --fc-num: var(--c-accent); }
.fact-card[data-accent='teal'] { --fc-accent: var(--c-teal-bright); --fc-border: rgba(0,168,146,0.30); --fc-num: var(--c-teal-bright); }
.fact-card[data-accent='red']  { --fc-accent: var(--c-cta); --fc-border: rgba(225,29,42,0.30); --fc-num: var(--c-cta-hover); }
.fact-num {
  font-family: var(--font-display);
  font-size: var(--fs-4xl);
  font-weight: var(--fw-extrabold);
  line-height: 1;
  color: var(--fc-num);
  text-shadow: 0 0 22px color-mix(in srgb, var(--fc-num) 30%, transparent);
}
.fact-num-text { font-size: var(--fs-3xl); }
.fact-label {
  font-family: var(--font-display);
  font-size: var(--fs-base);
  font-weight: var(--fw-semibold);
  color: var(--c-text);
}
.fact-note { font-size: var(--fs-xs); color: var(--c-text-dim); }

/* ── INHALTE / ABLAUF ────────────────────────────────────────────── */
.step-section {
  background: var(--c-bg-elevated);
  border-block: 1px solid var(--c-border);
}
.step-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  max-width: 880px;
  margin-inline: auto;
}
.step-card {
  position: relative;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: var(--sp-5);
  align-items: center;
  padding: var(--sp-6);
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: transform var(--t-base), border-color var(--t-base), box-shadow var(--t-base);
}
.step-card[data-accent='gold'] { --sc-accent: var(--c-accent); --sc-border: var(--c-border-gold); }
.step-card[data-accent='teal'] { --sc-accent: var(--c-teal-bright); --sc-border: rgba(0,168,146,0.30); }
.step-card[data-accent='red']  { --sc-accent: var(--c-cta-hover); --sc-border: rgba(225,29,42,0.30); }
.step-card:hover {
  transform: translateX(6px);
  border-color: var(--sc-border);
  box-shadow: 0 14px 34px rgba(0,0,0,0.30);
}
.step-line {
  position: absolute;
  inset: 0 auto 0 0;
  width: 3px;
  background: var(--sc-accent);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform var(--t-base);
}
.step-card:hover .step-line { transform: scaleY(1); }
.step-index {
  font-family: var(--font-display);
  font-size: var(--fs-5xl);
  font-weight: var(--fw-extrabold);
  line-height: 1;
  color: var(--sc-accent);
  opacity: 0.85;
  min-width: 1.6em;
  text-align: center;
  text-shadow: 0 0 26px color-mix(in srgb, var(--sc-accent) 28%, transparent);
}
.step-title {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  margin-bottom: var(--sp-2);
}
.step-desc {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}

/* ── VORAUSSETZUNGEN ─────────────────────────────────────────────── */
.req-inner {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: var(--sp-12);
  align-items: center;
}
.req-copy h2 { margin-bottom: var(--sp-4); }
.req-lead {
  font-size: var(--fs-lg);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}
.req-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}
.req-item {
  display: flex;
  align-items: flex-start;
  gap: var(--sp-4);
  padding: var(--sp-5);
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  transition: border-color var(--t-base), transform var(--t-base);
}
.req-item:hover {
  border-color: var(--c-accent-dim);
  transform: translateY(-3px);
}
.req-check {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: var(--r-full);
  background: color-mix(in srgb, var(--c-teal-bright) 16%, transparent);
  color: var(--c-teal-bright);
}
.req-title {
  font-size: var(--fs-base);
  font-weight: var(--fw-bold);
  margin-bottom: var(--sp-1);
}
.req-desc {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
}

/* ── PREIS AUF ANFRAGE ───────────────────────────────────────────── */
.price-card {
  position: relative;
  background: var(--grad-hero);
  border: 1px solid var(--c-border-gold);
  border-radius: var(--r-xl);
  padding: clamp(2rem, 4vw, 3.5rem);
  text-align: center;
  overflow: hidden;
  box-shadow: var(--sh-lg);
}
.price-glow {
  position: absolute;
  top: -180px;
  left: 50%;
  transform: translateX(-50%);
  width: 540px;
  max-width: 120%;
  height: 380px;
  background: radial-gradient(ellipse at center, var(--c-accent-glow), transparent 68%);
  pointer-events: none;
}
.price-content { position: relative; z-index: 1; }
.price-content .eyebrow { justify-content: center; }
.price-content h2 { margin-bottom: var(--sp-4); }
.price-lead {
  font-size: var(--fs-lg);
  color: var(--c-text-muted);
  line-height: var(--lh-relaxed);
  max-width: 560px;
  margin: 0 auto var(--sp-8);
}
.price-actions {
  display: flex;
  gap: var(--sp-4);
  justify-content: center;
  flex-wrap: wrap;
}

/* ── RESPONSIVE ──────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .intro-grid,
  .req-inner {
    grid-template-columns: 1fr;
    gap: var(--sp-8);
  }
}
@media (max-width: 600px) {
  .fact-cards { grid-template-columns: 1fr; }
  .step-card { grid-template-columns: 1fr; gap: var(--sp-2); text-align: left; }
  .step-index { text-align: left; }
  .intro-actions,
  .price-actions { flex-direction: column; }
  .intro-actions .btn,
  .price-actions .btn { width: 100%; }
}
</style>
