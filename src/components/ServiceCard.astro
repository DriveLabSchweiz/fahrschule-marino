---
import type { Service } from '@data/site';

interface Props {
  service: Service;
  href?: string;
}

const { service, href } = Astro.props;
const link = href || `/${service.slug}`;

const icons: Record<string, string> = {
  car: '<path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  'first-aid': '<path d="M9 3v18M3 9h18"/><path d="M12 3v3M12 15v3M9 3l6 0"/><rect x="3" y="3" width="18" height="18" rx="2"/>',
  check: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  motorcycle: '<path d="M3 17h2l1.4-1.4M14 17H9m9-7l-3 3M5 17a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>',
};
---

<a href={link} class="service-card reveal">
  <div class="service-icon">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[service.icon] || icons.car} />
  </div>
  <h3 class="service-name">{service.name}</h3>
  <p class="service-desc">{service.description}</p>
  {service.duration && <span class="service-duration">⏱ {service.duration}</span>}
  <span class="service-arrow">→</span>
</a>

<style>
.service-card {
  display: block;
  background: var(--grad-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  padding: var(--sp-6);
  transition: all var(--t-base);
  position: relative;
  overflow: hidden;
  height: 100%;
}

.service-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, var(--c-accent-dim), transparent 60%);
  opacity: 0;
  transition: opacity var(--t-base);
  pointer-events: none;
}

.service-card:hover {
  border-color: var(--c-accent-dim);
  transform: translateY(-4px);
  box-shadow: var(--sh-lg);
}

.service-card:hover::before {
  opacity: 1;
}

.service-icon {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-accent-dim);
  border-radius: var(--r-md);
  color: var(--c-accent);
  margin-bottom: var(--sp-4);
  transition: all var(--t-base);
}

.service-card:hover .service-icon {
  background: var(--c-accent);
  color: var(--c-bg);
  transform: scale(1.1);
}

.service-name {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  margin-bottom: var(--sp-2);
}

.service-desc {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  line-height: var(--lh-normal);
  margin-bottom: var(--sp-4);
}

.service-duration {
  display: inline-block;
  font-size: var(--fs-xs);
  color: var(--c-text-dim);
  padding: var(--sp-1) var(--sp-3);
  background: var(--c-surface);
  border-radius: var(--r-full);
}

.service-arrow {
  position: absolute;
  bottom: var(--sp-6);
  right: var(--sp-6);
  font-size: var(--fs-lg);
  color: var(--c-accent);
  opacity: 0;
  transform: translateX(-10px);
  transition: all var(--t-base);
}

.service-card:hover .service-arrow {
  opacity: 1;
  transform: translateX(0);
}
</style>
