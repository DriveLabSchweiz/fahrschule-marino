---
import { company, footerNav, physicalLocations } from '@data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-glow"></div>
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="logo-mark">AM</span>
          <span class="logo-text">Antonio Marino</span>
        </div>
        <p class="footer-tagline">
          Deine Fahrschule in der Region Lachen, Zürich und Rapperswil-Jona.
          Sicher, schnell und mit Spass zum Führerschein.
        </p>
        <div class="footer-social">
          <a href={company.socialMedia.facebook} target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07z"/></svg>
          </a>
          <a href={company.socialMedia.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.38C1.35 2.68.94 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.38.66-.67 1.07-1.34 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.31-.79-.72-1.46-1.38-2.13C20.32 1.35 19.65.94 18.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84c-3.4 0-6.16 2.76-6.16 6.16s2.76 6.16 6.16 6.16 6.16-2.76 6.16-6.16S15.4 5.84 12 5.84zM12 16a4 4 0 110-8 4 4 0 010 8zm6.41-10.85a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Leistungen</h4>
        <ul>
          {footerNav.leistungen.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div class="footer-col">
        <h4 class="footer-heading">Standorte</h4>
        <ul>
          {physicalLocations.map(loc => (
            <li><a href={`/fahrschule-${loc.slug}`}>{loc.name}</a></li>
          ))}
          <li><a href="/standorte">Alle Standorte →</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-heading">Kontakt</h4>
        <ul class="footer-contact">
          <li>
            <a href={`tel:${company.phone.replace(/\s/g, '')}`}>📞 {company.phone}</a>
          </li>
          <li>
            <a href={`mailto:${company.email}`}>✉️ {company.email}</a>
          </li>
        </ul>
        <h4 class="footer-heading" style="margin-top: var(--sp-5);">Rechtliches</h4>
        <ul>
          {footerNav.rechtliches.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {company.name}. Alle Rechte vorbehalten.</p>
      <p class="footer-langs">🌐 Unterricht in {company.languages.join(', ')}</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  position: relative;
  background: var(--c-bg-elevated);
  border-top: 1px solid var(--c-border);
  padding-top: var(--sp-12);
  padding-bottom: var(--sp-6);
  overflow: hidden;
}

.footer-glow {
  position: absolute;
  top: -100px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 200px;
  background: radial-gradient(ellipse at center, var(--c-accent-dim), transparent 70%);
  pointer-events: none;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: var(--sp-8);
  margin-bottom: var(--sp-10);
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  font-family: var(--font-display);
  font-weight: var(--fw-extrabold);
  margin-bottom: var(--sp-4);
}

.footer-logo .logo-mark {
  width: 36px; height: 36px;
  background: var(--grad-accent);
  color: var(--c-bg);
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--r-md);
  font-size: var(--fs-xs);
  box-shadow: var(--sh-glow);
}

.footer-logo .logo-text {
  font-size: var(--fs-base);
}

.footer-tagline {
  color: var(--c-text-muted);
  font-size: var(--fs-sm);
  max-width: 300px;
  margin-bottom: var(--sp-5);
}

.footer-social {
  display: flex;
  gap: var(--sp-3);
}

.footer-social a {
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-surface);
  border-radius: var(--r-md);
  color: var(--c-text-muted);
  transition: all var(--t-fast);
}

.footer-social a:hover {
  background: var(--c-accent);
  color: var(--c-bg);
  transform: translateY(-2px);
}

.footer-heading {
  font-size: var(--fs-sm);
  font-weight: var(--fw-semibold);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--c-accent);
  margin-bottom: var(--sp-4);
}

.footer-col ul {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.footer-col a {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  transition: color var(--t-fast);
}

.footer-col a:hover {
  color: var(--c-accent);
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--sp-6);
  border-top: 1px solid var(--c-border);
  font-size: var(--fs-xs);
  color: var(--c-text-dim);
}

@media (max-width: 768px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
  .footer-bottom {
    flex-direction: column;
    gap: var(--sp-2);
    text-align: center;
  }
}

@media (max-width: 480px) {
  .footer-grid {
    grid-template-columns: 1fr;
  }
}
</style>
