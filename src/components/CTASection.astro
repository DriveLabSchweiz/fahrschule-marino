---
import { company } from '@data/site';

interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'default' | 'compact';
}

const {
  title = 'Bereit für deine erste Fahrstunde?',
  subtitle = 'Kontaktiere Antonio jetzt – per Telefon, WhatsApp oder Formular. Du erhältst innerhalb von 24 Stunden eine Antwort.',
  variant = 'default',
} = Astro.props;

const phoneLink = company.phone.replace(/\s/g, '');
---

<section class={`cta-section ${variant === 'compact' ? 'cta-compact' : ''}`}>
  <div class="container">
    <div class="cta-card reveal">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <h2 class="cta-title">{title}</h2>
        <p class="cta-subtitle">{subtitle}</p>
        <div class="cta-actions">
          <a href={`tel:${phoneLink}`} class="btn btn-cta btn-lg btn-magnetic">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {company.phone}
          </a>
          <a href={`https://wa.me/41${phoneLink.replace('+41', '')}?text=Hallo%20Antonio,%20ich%20möchte%20Fahrstunden%20buchen.`}
             target="_blank" rel="noopener" class="btn btn-ghost btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm5.49-7.415c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            WhatsApp
          </a>
          <a href="/kontakt" class="btn btn-primary btn-lg">
            Formular
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.cta-section {
  padding-block: clamp(3rem, 6vw, 6rem);
}

.cta-card {
  position: relative;
  background: var(--grad-hero);
  border: 1px solid var(--c-border-strong);
  border-radius: var(--r-xl);
  padding: clamp(2rem, 5vw, 5rem);
  overflow: hidden;
  text-align: center;
}

.cta-glow {
  position: absolute;
  top: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 400px;
  background: radial-gradient(ellipse at center, var(--c-accent-dim), transparent 70%);
  pointer-events: none;
}

.cta-content {
  position: relative;
  z-index: 1;
}

.cta-title {
  font-size: clamp(1.5rem, 3vw + 1rem, 2.5rem);
  margin-bottom: var(--sp-4);
}

.cta-subtitle {
  color: var(--c-text-muted);
  font-size: var(--fs-lg);
  max-width: 600px;
  margin-inline: auto;
  margin-bottom: var(--sp-8);
}

.cta-actions {
  display: flex;
  gap: var(--sp-4);
  justify-content: center;
  flex-wrap: wrap;
}

.cta-compact .cta-card {
  padding: clamp(1.5rem, 3vw, 3rem);
}

.cta-compact .cta-title {
  font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
}

@media (max-width: 768px) {
  .cta-actions {
    flex-direction: column;
    width: 100%;
  }
  .cta-actions .btn {
    width: 100%;
  }
}
</style>
