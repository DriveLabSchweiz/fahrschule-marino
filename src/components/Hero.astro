---
interface Props {
  eyebrow?: string;
  title: string;
  titleHighlight?: string;
  subtitle?: string;
  showCTA?: boolean;
  backgroundVariant?: 'default' | 'minimal';
}

const {
  eyebrow = 'Fahrschule Antonio Marino',
  title,
  titleHighlight,
  subtitle,
  showCTA = true,
  backgroundVariant = 'default',
} = Astro.props;
---

<section class={`hero ${backgroundVariant === 'minimal' ? 'hero-minimal' : ''}`}>
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="road-lines">
      <div class="road-line road-line-1"></div>
      <div class="road-line road-line-2"></div>
      <div class="road-line road-line-3"></div>
    </div>
  </div>

  <div class="container hero-content">
    <p class="eyebrow reveal">{eyebrow}</p>
    <h1 class="hero-title reveal reveal-delay-1">
      {title}
      {titleHighlight && <span class="hero-highlight">{titleHighlight}</span>}
    </h1>
    {subtitle && <p class="hero-subtitle reveal reveal-delay-2">{subtitle}</p>}

    {showCTA && (
      <div class="hero-actions reveal reveal-delay-3">
        <a href="/kontakt" class="btn btn-primary btn-lg btn-magnetic">
          Termin buchen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/fahrstunden" class="btn btn-ghost btn-lg">
          Leistungen ansehen
        </a>
      </div>
    )}

    <div class="hero-stats reveal reveal-delay-4">
      <div class="hero-stat">
        <span class="hero-stat-num">6</span>
        <span class="hero-stat-label">Standorte</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">5</span>
        <span class="hero-stat-label">Sprachen</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">10+</span>
        <span class="hero-stat-label">Jahre Erfahrung</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator" aria-hidden="true">
    <span class="scroll-text">Scrollen</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding-top: var(--header-height);
  overflow: hidden;
}

.hero-minimal {
  min-height: 60vh;
}

/* Background */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(245, 182, 20, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245, 182, 20, 0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
}

.hero-glow {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 600px;
  background: radial-gradient(ellipse at center, rgba(245, 182, 20, 0.12), transparent 60%);
  pointer-events: none;
}

/* Animated road lines */
.road-lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.road-line {
  position: absolute;
  height: 2px;
  background: repeating-linear-gradient(
    90deg,
    var(--c-accent) 0,
    var(--c-accent) 50px,
    transparent 50px,
    transparent 100px
  );
  opacity: 0.15;
}

.road-line-1 {
  width: 200%;
  top: 25%;
  left: -50%;
  transform: rotate(-5deg);
  animation: roadDash 4s linear infinite;
}

.road-line-2 {
  width: 200%;
  top: 55%;
  left: -50%;
  transform: rotate(3deg);
  opacity: 0.1;
  animation: roadDash 6s linear infinite reverse;
}

.road-line-3 {
  width: 200%;
  top: 80%;
  left: -50%;
  transform: rotate(-2deg);
  opacity: 0.08;
  animation: roadDash 5s linear infinite;
}

/* Content */
.hero-content {
  position: relative;
  z-index: 1;
  max-width: var(--container-max);
}

.hero-title {
  font-size: clamp(2.5rem, 6vw + 1rem, 5rem);
  font-weight: var(--fw-extrabold);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: var(--sp-5);
  max-width: 900px;
}

.hero-highlight {
  display: block;
  background: var(--grad-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.25rem);
  color: var(--c-text-muted);
  max-width: 600px;
  margin-bottom: var(--sp-8);
  line-height: var(--lh-relaxed);
}

.hero-actions {
  display: flex;
  gap: var(--sp-4);
  flex-wrap: wrap;
  margin-bottom: var(--sp-12);
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  gap: var(--sp-6);
}

.hero-stat {
  display: flex;
  flex-direction: column;
}

.hero-stat-num {
  font-family: var(--font-display);
  font-size: var(--fs-3xl);
  font-weight: var(--fw-extrabold);
  color: var(--c-accent);
  line-height: 1;
}

.hero-stat-label {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
  margin-top: var(--sp-1);
}

.hero-stat-divider {
  width: 1px;
  height: 40px;
  background: var(--c-border-strong);
}

/* Scroll indicator */
.hero-scroll-indicator {
  position: absolute;
  bottom: var(--sp-6);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-2);
  opacity: 0.5;
}

.scroll-text {
  font-size: var(--fs-xs);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--c-text-muted);
}

.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--c-accent), transparent);
  animation: scrollDown 2s ease-in-out infinite;
}

@keyframes scrollDown {
  0% { transform: translateY(-100%); opacity: 0; }
  50% { opacity: 1; }
  100% { transform: translateY(100%); opacity: 0; }
}

/* Responsive */
@media (max-width: 768px) {
  .hero {
    min-height: 90vh;
  }
  .hero-stats {
    gap: var(--sp-4);
  }
  .hero-stat-num {
    font-size: var(--fs-2xl);
  }
  .hero-stat-divider {
    height: 30px;
  }
  .hero-scroll-indicator {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .road-line { animation: none; }
  .scroll-line { animation: none; }
}
</style>
