---
interface Props {
  eyebrow?: string;
  title: string;
  titleHighlight?: string;
  subtitle?: string;
  showCTA?: boolean;
  backgroundVariant?: 'default' | 'minimal';
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow = 'Fahrschule Antonio Marino',
  title,
  titleHighlight,
  subtitle,
  showCTA = true,
  backgroundVariant = 'default',
  image,
  imageAlt = 'Antonio Marino mit seinem Fahrschulauto',
} = Astro.props;

const isMinimal = backgroundVariant === 'minimal';
const hasImage = !!image && !isMinimal;
---

<section class={`hero ${isMinimal ? 'hero-minimal' : ''} ${hasImage ? 'has-image' : ''}`}>
  <!-- ============ LAYERED PARALLAX BACKGROUND ============ -->
  <div class="hero-bg" aria-hidden="true">
    <!-- teal depth gradient base -->
    <div class="hero-depth"></div>
    <!-- gold radial glow (parallax, slow) -->
    <div class="hero-glow" data-parallax data-parallax-speed="0.06"></div>
    <!-- faint grid + grain -->
    <div class="hero-grid" data-parallax data-parallax-speed="0.1"></div>
    <!-- perspective road converging to vanishing point -->
    <div class="hero-road" data-parallax data-parallax-speed="0.04">
      <div class="road-floor">
        <span class="road-edge road-edge-l"></span>
        <span class="road-edge road-edge-r"></span>
        <span class="road-dashes"></span>
      </div>
      <div class="road-vanish"></div>
      <div class="road-horizon"></div>
    </div>
    <!-- drifting ambient road-lines (decorative) -->
    <div class="ambient-lines" data-parallax data-parallax-speed="0.14">
      <span class="ambient-line ambient-line-1"></span>
      <span class="ambient-line ambient-line-2"></span>
      <span class="ambient-line ambient-line-3"></span>
    </div>
    <!-- top + bottom fades for legibility -->
    <div class="hero-vignette"></div>
  </div>

  <!-- ============ CONTENT (hero entrance timeline drives [data-hero]) ============ -->
  <div class="container hero-inner">
  <div class="hero-content">
    <p class="eyebrow hero-eyebrow" data-hero>
      <img
        class="hero-emblem"
        src="/logo-marino-emblem.png"
        alt="Logo Fahrschule Antonio Marino"
        width="34"
        height="26"
        decoding="async"
        loading="eager"
      />
      <span>{eyebrow}</span>
    </p>

    <h1 class="hero-title" data-hero>
      <span class="hero-title-line">{title}</span>
      {titleHighlight && <span class="hero-highlight">{titleHighlight}</span>}
    </h1>

    {subtitle && <p class="hero-subtitle" data-hero>{subtitle}</p>}

    {showCTA && (
      <div class="hero-actions" data-hero>
        <a href="/kontakt" class="btn btn-primary btn-lg btn-magnetic">
          Termin buchen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/leistungen" class="btn btn-ghost btn-lg">
          Leistungen ansehen
        </a>
      </div>
    )}

    {!isMinimal && (
      <div class="hero-stats" data-hero>
        <div class="hero-stat">
          <span class="hero-stat-num" data-count="6">6</span>
          <span class="hero-stat-label">Standorte</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-num" data-count="5">5</span>
          <span class="hero-stat-label">Sprachen</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-num" data-count="10" data-count-suffix="+">10+</span>
          <span class="hero-stat-label">Jahre Erfahrung</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-num hero-stat-rating" data-count="4.9" data-count-decimals="1">4.9<span class="hero-stat-star" aria-hidden="true">★</span></span>
          <span class="hero-stat-label">Google-Bewertung</span>
        </div>
      </div>
    )}
  </div>

  {hasImage && (
    <div class="hero-media" data-hero>
      <div class="hero-media-frame">
        <img
          class="hero-media-img"
          src={image}
          alt={imageAlt}
          width="800"
          height="600"
          decoding="async"
          loading="eager"
        />
        <span class="hero-media-shine" aria-hidden="true"></span>
      </div>
      <span class="hero-media-badge">
        <span class="hero-media-badge-star" aria-hidden="true">★</span>
        <span><strong>4.9</strong>&nbsp;/&nbsp;5 · 63&nbsp;Google-Bewertungen</span>
      </span>
    </div>
  )}
  </div>

  {!isMinimal && (
    <div class="hero-scroll-indicator" aria-hidden="true">
      <span class="scroll-text">Scrollen</span>
      <span class="scroll-line"></span>
    </div>
  )}
</section>

<style>
/* ============================================================
   HERO — cinematic, kinetic, BALLERT.
   Gold leads · teal grounds · red energizes · near-black base.
   All colours via CSS vars from global.css (no raw hex).
   ============================================================ */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  padding-top: calc(var(--header-height) + var(--sp-6));
  padding-bottom: var(--sp-10);
  overflow: hidden;
  isolation: isolate;
}

.hero-minimal {
  min-height: 52vh;
  padding-top: calc(var(--header-height) + var(--sp-8));
  padding-bottom: var(--sp-8);
}

/* ---------- BACKGROUND STACK ---------- */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}

/* teal depth gradient base */
.hero-depth {
  position: absolute;
  inset: -10%;
  background:
    radial-gradient(120% 90% at 50% 8%, rgba(0, 112, 99, 0.32), transparent 60%),
    var(--grad-hero);
}

/* gold radial glow (parallax) */
.hero-glow {
  position: absolute;
  top: -12%;
  left: 50%;
  width: min(960px, 120vw);
  height: min(760px, 95vh);
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, var(--c-accent-glow), transparent 62%);
  opacity: 0.5;
  mix-blend-mode: screen;
  filter: blur(8px);
}

/* faint grid + grain */
.hero-grid {
  position: absolute;
  inset: -20%;
  background-image:
    linear-gradient(rgba(255, 174, 53, 0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 174, 53, 0.045) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 10%, transparent 72%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 10%, transparent 72%);
}

/* ---------- PERSPECTIVE ROAD ---------- */
.hero-road {
  position: absolute;
  inset: 0;
  perspective: 520px;
  perspective-origin: 50% 22%;
}

/* the receding asphalt plane */
.road-floor {
  position: absolute;
  left: 50%;
  bottom: -6%;
  width: 200%;
  height: 78%;
  transform: translateX(-50%) rotateX(74deg);
  transform-origin: 50% 100%;
  background:
    radial-gradient(ellipse 60% 120% at 50% 100%, rgba(0, 112, 99, 0.16), transparent 70%);
  mask-image: linear-gradient(to top, black 8%, transparent 86%);
  -webkit-mask-image: linear-gradient(to top, black 8%, transparent 86%);
}

/* gold road edges converging to the vanishing point */
.road-edge {
  position: absolute;
  bottom: 0;
  width: 3px;
  height: 100%;
  background: linear-gradient(to top, var(--c-accent), rgba(255, 174, 53, 0));
  opacity: 0.42;
  filter: drop-shadow(0 0 6px var(--c-accent-glow));
}
.road-edge-l {
  left: 18%;
  transform-origin: bottom center;
  transform: rotate(20deg);
}
.road-edge-r {
  right: 18%;
  transform-origin: bottom center;
  transform: rotate(-20deg);
}

/* moving centre dashes (gold) — the "BALLERN" motion */
.road-dashes {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 14px;
  height: 100%;
  transform: translateX(-50%);
  background: repeating-linear-gradient(
    to top,
    var(--c-accent-bright) 0,
    var(--c-accent-bright) 26px,
    transparent 26px,
    transparent 64px
  );
  opacity: 0.55;
  filter: drop-shadow(0 0 8px var(--c-accent-glow));
  mask-image: linear-gradient(to top, black 4%, transparent 80%);
  -webkit-mask-image: linear-gradient(to top, black 4%, transparent 80%);
  animation: roadRush 1.6s linear infinite;
}

@keyframes roadRush {
  from { background-position: 0 0; }
  to   { background-position: 0 64px; }
}

/* vanishing-point bloom */
.road-vanish {
  position: absolute;
  left: 50%;
  top: 21%;
  width: 220px;
  height: 220px;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, var(--c-accent-glow) 0%, rgba(255, 174, 53, 0.12) 28%, transparent 60%);
  filter: blur(2px);
}

/* thin teal horizon line at the vanishing point */
.road-horizon {
  position: absolute;
  left: 50%;
  top: 21%;
  width: min(560px, 80vw);
  height: 1px;
  transform: translateX(-50%);
  background: linear-gradient(90deg, transparent, var(--c-teal-bright), transparent);
  opacity: 0.5;
}

/* ---------- DRIFTING AMBIENT LINES ---------- */
.ambient-lines {
  position: absolute;
  inset: 0;
}
.ambient-line {
  position: absolute;
  left: -50%;
  width: 200%;
  height: 2px;
  background: repeating-linear-gradient(
    90deg,
    var(--c-accent) 0,
    var(--c-accent) 44px,
    transparent 44px,
    transparent 90px
  );
}
.ambient-line-1 { top: 30%; transform: rotate(-4deg); opacity: 0.08; animation: ambientDrift 7s linear infinite; }
.ambient-line-2 { top: 62%; transform: rotate(3deg);  opacity: 0.06; animation: ambientDrift 9s linear infinite reverse; }
.ambient-line-3 { top: 84%; transform: rotate(-2deg); opacity: 0.05; animation: ambientDrift 6s linear infinite; }

@keyframes ambientDrift {
  to { background-position: 90px 0; }
}

/* legibility vignette */
.hero-vignette {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(11, 15, 14, 0.55) 0%, transparent 22%, transparent 60%, rgba(11, 15, 14, 0.92) 100%),
    radial-gradient(120% 80% at 30% 40%, transparent 40%, rgba(11, 15, 14, 0.5) 100%);
}

/* ---------- CONTENT ---------- */
.hero-content {
  position: relative;
  z-index: 1;
  max-width: 980px;
}

/* eyebrow with floating gold emblem badge */
.hero-eyebrow {
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-2) var(--sp-4) var(--sp-2) var(--sp-2);
  border: 1px solid var(--c-border-gold);
  border-radius: var(--r-full);
  background: rgba(17, 32, 28, 0.5);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  margin-bottom: var(--sp-5);
}
/* override the default eyebrow's leading dash — we lead with the emblem */
.hero-eyebrow::before { display: none; }

.hero-emblem {
  width: 34px;
  height: 26px;
  object-fit: contain;
  filter: drop-shadow(0 0 10px var(--c-accent-glow));
  animation: emblemFloat 5s ease-in-out infinite;
}

@keyframes emblemFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-3px); }
}

/* huge bold headline */
.hero-title {
  font-size: clamp(2.6rem, 6.2vw + 1rem, 5.4rem);
  font-weight: var(--fw-extrabold);
  line-height: 1.02;
  letter-spacing: -0.035em;
  margin-bottom: var(--sp-5);
  max-width: 16ch;
}
.hero-minimal .hero-title {
  font-size: clamp(2.2rem, 4.4vw + 1rem, 3.9rem);
}

.hero-title-line { display: block; color: var(--c-text); }

/* gold gradient highlight with animated underline-swipe */
.hero-highlight {
  display: inline-block;
  position: relative;
  background: var(--grad-accent);
  background-size: 200% auto;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  animation: goldShift 6s ease-in-out infinite;
}
.hero-highlight::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0.04em;
  width: 100%;
  height: 0.09em;
  border-radius: var(--r-full);
  background: var(--grad-accent);
  box-shadow: 0 0 18px var(--c-accent-glow);
  transform: scaleX(0);
  transform-origin: left center;
  animation: underlineSwipe 1s var(--t-spring) 0.85s forwards;
}

@keyframes goldShift {
  0%, 100% { background-position: 0% center; }
  50%      { background-position: 100% center; }
}
@keyframes underlineSwipe {
  to { transform: scaleX(1); }
}

.hero-subtitle {
  font-size: clamp(1rem, 1.1vw + 0.7rem, 1.3rem);
  color: var(--c-text-muted);
  max-width: 60ch;
  margin-bottom: var(--sp-8);
  line-height: var(--lh-relaxed);
}
.hero-minimal .hero-subtitle { margin-bottom: var(--sp-6); }

.hero-actions {
  display: flex;
  gap: var(--sp-4);
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: var(--sp-10);
}
.hero-minimal .hero-actions { margin-bottom: 0; }

/* ---------- STATS ---------- */
.hero-stats {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-5) var(--sp-6);
  padding-top: var(--sp-6);
  border-top: 1px solid var(--c-border);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
}

.hero-stat-num {
  display: inline-flex;
  align-items: baseline;
  font-family: var(--font-display);
  font-size: clamp(1.7rem, 1vw + 1.4rem, 2.4rem);
  font-weight: var(--fw-extrabold);
  color: var(--c-accent);
  line-height: 1;
  letter-spacing: -0.02em;
  text-shadow: 0 0 22px var(--c-accent-dim);
  font-variant-numeric: tabular-nums;
}

.hero-stat-star {
  color: var(--c-accent-bright);
  font-size: 0.7em;
  margin-left: 0.12em;
}

.hero-stat-label {
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
}

.hero-stat-divider {
  width: 1px;
  height: 36px;
  background: var(--c-border-strong);
}

/* ---------- SCROLL CUE ---------- */
.hero-scroll-indicator {
  position: absolute;
  bottom: var(--sp-5);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-2);
  z-index: 1;
}

.scroll-text {
  font-family: var(--font-display);
  font-size: var(--fs-xs);
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: var(--c-text-dim);
}

.scroll-line {
  position: relative;
  width: 1px;
  height: 44px;
  overflow: hidden;
  background: rgba(255, 174, 53, 0.12);
}
.scroll-line::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, var(--c-accent), transparent);
  animation: scrollDown 1.9s ease-in-out infinite;
}

@keyframes scrollDown {
  0%   { transform: translateY(-100%); opacity: 0; }
  40%  { opacity: 1; }
  100% { transform: translateY(100%); opacity: 0; }
}

/* ---------- TWO-COLUMN (homepage hero with car photo) ---------- */
.hero-inner { position: relative; z-index: 1; }
.has-image .hero-inner {
  display: grid;
  grid-template-columns: minmax(0, 1.04fr) minmax(0, 0.96fr);
  align-items: center;
  gap: var(--sp-8);
}
.has-image .hero-content { max-width: 600px; }

.hero-media {
  position: relative;
  justify-self: end;
  width: 100%;
  max-width: 560px;
}

.hero-media-frame {
  position: relative;
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 1px solid var(--c-border-gold);
  background: var(--c-surface);
  box-shadow: var(--sh-lg), 0 0 64px rgba(0, 112, 99, 0.28), 0 0 24px var(--c-accent-dim);
  animation: heroCarFloat 7s ease-in-out infinite;
}
.hero-media-frame::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, transparent 52%, rgba(11, 15, 14, 0.55) 100%);
  pointer-events: none;
}

.hero-media-img {
  width: 100%;
  height: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
}

.hero-media-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(115deg, transparent 42%, rgba(255, 174, 53, 0.22) 50%, transparent 58%);
  transform: translateX(-100%);
  animation: heroShine 6s ease-in-out 1.6s infinite;
}

.hero-media-badge {
  position: absolute;
  left: 16px;
  bottom: 16px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-2) var(--sp-4);
  background: rgba(17, 32, 28, 0.82);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid var(--c-border-gold);
  border-radius: var(--r-full);
  font-size: var(--fs-sm);
  color: var(--c-text);
  box-shadow: var(--sh-md);
}
.hero-media-badge strong {
  color: var(--c-accent);
  font-family: var(--font-display);
  font-size: var(--fs-lg);
}
.hero-media-badge-star { color: var(--c-accent-bright); font-size: 1.05em; }

@keyframes heroCarFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-9px); }
}
@keyframes heroShine {
  0%, 45%  { transform: translateX(-100%); }
  70%, 100% { transform: translateX(100%); }
}

@media (max-width: 900px) {
  .has-image .hero-inner { grid-template-columns: 1fr; gap: var(--sp-6); }
  .has-image .hero-content { max-width: 640px; }
  .hero-media { justify-self: start; max-width: 480px; }
}

/* ---------- RESPONSIVE ---------- */
@media (max-width: 768px) {
  .hero { min-height: 92svh; }
  .hero-stats { gap: var(--sp-4) var(--sp-5); }
  .hero-stat-divider { height: 30px; }
  .hero-stat-divider:nth-of-type(2) { display: none; }
  .hero-scroll-indicator { display: none; }
  .road-floor { height: 64%; }
}

@media (max-width: 480px) {
  .hero-actions .btn { width: 100%; }
}

/* ---------- REDUCED MOTION ---------- */
@media (prefers-reduced-motion: reduce) {
  .road-dashes,
  .ambient-line-1, .ambient-line-2, .ambient-line-3,
  .hero-emblem,
  .hero-highlight,
  .hero-media-frame,
  .hero-media-shine,
  .scroll-line::after { animation: none; }
  .hero-highlight::after { transform: scaleX(1); animation: none; }
  .hero-highlight {
    background-position: 0% center;
  }
}
</style>
