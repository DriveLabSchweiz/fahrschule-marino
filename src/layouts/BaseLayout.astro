---
import '@styles/global.css';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import StickyMobileCTA from '@components/StickyMobileCTA.astro';
import GsapController from '@components/GsapController.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const { title, description, canonical, ogImage, noindex, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="de-CH">
<head>
  <SEO title={title} description={description} canonical={canonical} ogImage={ogImage} noindex={noindex} schema={schema} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <a href="#main" class="skip-link">Zum Inhalt springen</a>

  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" aria-hidden="true">
    <div class="scroll-progress-bar" data-scroll-progress></div>
  </div>

  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <StickyMobileCTA />
  <GsapController />

  <style>
    .scroll-progress {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 3px;
      z-index: 9998;
      background: rgba(255,255,255,0.05);
    }
    .scroll-progress-bar {
      height: 100%;
      width: 100%;
      background: var(--grad-cta);
      transform-origin: left;
      transform: scaleX(0);
    }
  </style>
</body>
</html>
