# Cloudflare Turnstile (Spam-Schutz für Kontaktformular)
# Beantrage deinen Key unter: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=0x4XXXXXXXXXXXXXXXXX
TURNSTILE_SECRET_KEY=0x0XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# E-Mail-Versand (optional — wähle einen Provider)
# Option 1: Resend
RESEND_API_KEY=re_xxxxxxxxxxxx

# Option 2: Mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxx
MAILGUN_DOMAIN=mail.fahrschule-marino.ch

# Option 3: Cloudflare Email Routing
EMAIL_TO=Antoniomarino@gmx.ch
EMAIL_FROM=formular@fahrschule-marino.ch
